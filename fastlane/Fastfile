# This file contains the fastlane.tools configuration
# You can find the documentation at https://docs.fastlane.tools
#
# For a list of all available actions, check out
#
#     https://docs.fastlane.tools/actions
#
# For a list of all available plugins, check out
#
#     https://docs.fastlane.tools/plugins/available-plugins
#

# Uncomment the line if you want fastlane to automatically update itself
# update_fastlane

def changelog(pr_number, pr_title, commit_sha, commit_message)
  prefix = pr_number.to_s.empty? ? pr_title : "PR ##{pr_number}: #{pr_title}"
  "#{prefix}\n#{commit_sha} #{commit_message}"
end

platform :ios do
  desc "Build, install on connected device, and upload dSYMs"
  lane :device do
    sync_code_signing(type: "adhoc")

    update_code_signing_settings(
      path: "ios/Runner.xcodeproj",
      sdk: "iphoneos*",
      code_sign_identity: "iPhone Distribution",
      profile_name: "match AdHoc #{ENV["FASTLANE_APP_IDENTIFIER"]}",
    )

    archive_path = flutter_build(
      build: "ipa",
      build_args: ["--no-codesign", "--dart-define=USE_FIREBASE=true"],
    )

    build_app(
      skip_build_archive: true,
      archive_path: archive_path,
      export_team_id: ENV["FASTLANE_TEAM_ID"],
      export_method: "ad-hoc",
      suppress_xcode_output: true,
    )

    install_on_device(ipa: lane_context[SharedValues::IPA_OUTPUT_PATH])

    Dir.chdir("..") { sh("dart", "run", "tool/credentials.dart", "fetch") }

    upload_symbols_to_crashlytics(
      dsym_path: lane_context[SharedValues::DSYM_OUTPUT_PATH],
      gsp_path: "ios/Runner/GoogleService-Info.plist",
      binary_path: "ios/Pods/FirebaseCrashlytics/upload-symbols",
    )
  end

  desc "Build and upload to TestFlight"
  lane :upload_testflight do |options|
    build_number = options[:build_number] || ENV["BUILD_NUMBER"] || 1
    pr_number = options[:pr_number] || ENV["PR_NUMBER"] || ""
    pr_title = options[:pr_title] || ENV["PR_TITLE"] || "manual build"
    commit_sha = options[:commit_sha] || ENV["COMMIT_SHA"] || "manual build"
    commit_message = options[:commit_message] || ENV["COMMIT_MESSAGE"] || "This is a manual build without PR information"
    skip_upload = options[:skip_upload].to_s == "true"
    public_tester = options[:public_tester].to_s == "true" 

    setup_ci if is_ci

    sync_code_signing(
      type: "appstore",
      readonly: is_ci,
    )

    update_code_signing_settings(
      path: "ios/Runner.xcodeproj",
      sdk: "iphoneos*",
      code_sign_identity: "iPhone Distribution",
      profile_name: "match AppStore #{ENV["FASTLANE_APP_IDENTIFIER"]}",
    )

    # Build and create xcarchive without code signing
    archive_path = flutter_build(
      build: "ipa",
      build_number: build_number,
      build_args: ["--no-codesign", "--dart-define=USE_FIREBASE=true"],
    )

    build_app(
      skip_build_archive: true,
      archive_path: archive_path,
      export_team_id: ENV["FASTLANE_TEAM_ID"],
      suppress_xcode_output: true,
    )

    next if skip_upload

    Dir.chdir("..") { sh("dart", "run", "tool/credentials.dart", "fetch") }

    upload_symbols_to_crashlytics(
      dsym_path: lane_context[SharedValues::DSYM_OUTPUT_PATH],
      gsp_path: "ios/Runner/GoogleService-Info.plist",
      binary_path: "ios/Pods/FirebaseCrashlytics/upload-symbols",
    )

    app_store_connect_api_key(
      is_key_content_base64: true,
    )

    changelog = changelog(pr_number, pr_title, commit_sha, commit_message)

    target_groups = ["Private External Testing"]
    target_groups << "Public External Testing" if public_tester

    upload_to_testflight(
      skip_waiting_for_build_processing: is_ci,
      changelog: changelog,
      distribute_external: true,
      groups: target_groups,
    )
  end
end

platform :android do
  private_lane :build_appbundle do |options|
    build_number = options[:build_number] || ENV["BUILD_NUMBER"] || 1
    Dir.chdir("..") { sh("dart", "run", "tool/credentials.dart", "fetch") }

    aab_path = flutter_build(
      build: "appbundle",
      build_number: build_number,
      build_args: ["--dart-define=USE_FIREBASE=true"],
    )
    aab_path
  end

  private_lane :upload_firebase do |options|
    pr_number = options[:pr_number] || ENV["PR_NUMBER"] || ""
    pr_title = options[:pr_title] || ENV["PR_TITLE"] || "manual build"
    commit_sha = options[:commit_sha] || ENV["COMMIT_SHA"] || "manual build"
    commit_message = options[:commit_message] || ENV["COMMIT_MESSAGE"] || "This is a manual build without PR information"
    public_tester = options[:public_tester].to_s == "true" || ENV["PUBLIC_TESTER"].to_s == "true"

    changelog_text = changelog(pr_number, pr_title, commit_sha, commit_message)
    aab_path = options[:aab] || File.expand_path("../build/app/outputs/bundle/release/app-release.aab", __dir__)

    release = firebase_app_distribution(
      groups: public_tester ? "pub-tester" : "dev-tester",
      release_notes: changelog_text,
      android_artifact_type: "AAB",
      android_artifact_path: aab_path,
      service_credentials_file: File.expand_path("../service-account.json", __dir__),
    )

    if ENV["GITHUB_OUTPUT"]
      File.open(ENV["GITHUB_OUTPUT"], "a") do |f|
        f.puts "testing_uri=#{release[:testingUri]}"
      end
    end
  end

  private_lane :upload_playstore do |options|
    build_number = options[:build_number] || ENV["BUILD_NUMBER"] || 1
    pr_number = options[:pr_number] || ENV["PR_NUMBER"] || ""
    pr_title = options[:pr_title] || ENV["PR_TITLE"] || "manual build"
    commit_sha = options[:commit_sha] || ENV["COMMIT_SHA"] || "manual build"
    commit_message = options[:commit_message] || ENV["COMMIT_MESSAGE"] || "This is a manual build without PR information"

    changelog_text = changelog(pr_number, pr_title, commit_sha, commit_message)
    ["zh-TW"].each do |locale|
      path = "metadata/android/#{locale}/changelogs"
      FileUtils.mkdir_p(path)
      File.write("#{path}/#{build_number}.txt", changelog_text)
    end

    aab_path = options[:aab] || File.expand_path("../build/app/outputs/bundle/release/app-release.aab", __dir__)

    upload_to_play_store(
      package_name: ENV["FASTLANE_APP_IDENTIFIER"],
      track: "internal",
      aab: aab_path,
      json_key: File.expand_path("../service-account.json", __dir__),
      skip_upload_metadata: false,
      skip_upload_images: true,
      skip_upload_screenshots: true,
      skip_upload_changelogs: false
    )
  end

  desc "Build the Android App Bundle"
  lane :build do |options|
    build_appbundle(options)
  end

  desc "Build and upload PR preview to Firebase App Distribution"
  lane :preview do |options|
    aab = options[:aab]
    aab ||= build_appbundle(options) unless options[:skip_build].to_s == "true"
    upload_firebase(options.merge(aab: aab)) unless options[:skip_upload].to_s == "true"
  end

  desc "Build and upload to Google Play Console"
  lane :release_googleplay do |options|
    aab = options[:aab]
    aab ||= build_appbundle(options) unless options[:skip_build].to_s == "true"
    upload_playstore(options.merge(aab: aab)) unless options[:skip_upload].to_s == "true"
  end

  desc "Build and upload to Firebase App Distribution"
  lane :release_firebase do |options|
    aab = options[:aab]
    aab ||= build_appbundle(options) unless options[:skip_build].to_s == "true"
    upload_firebase(options.merge(aab: aab)) unless options[:skip_upload].to_s == "true"
  end

  desc "Build and upload to Google Play Console & Firebase"
  lane :release do |options|
    aab = options[:aab]
    aab ||= build_appbundle(options) unless options[:skip_build].to_s == "true"
    upload_playstore(options.merge(aab: aab)) unless options[:skip_upload_playstore].to_s == "true"
    upload_firebase(options.merge(aab: aab)) unless options[:skip_upload_firebase].to_s == "true"
  end
end
